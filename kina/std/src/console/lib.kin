import { stdio } from "../stdio/lib.kin"

export func log(value: string): void {
  stdio.stdout.printLine(value)
}

export func read(): string {
  return stdio.stdin.readLine()
}

export struct IConsole {
  log: (string) -> void,
  read: () -> string
}

export val console: IConsole = {
  log: log,
  read: read
}
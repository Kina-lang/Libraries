import { 
  kina_lib_kina_std_console_printInt,
  kina_lib_kina_std_console_printBool
} from extern "../c/console.c"

export func printInt(value: int): void {
  kina_lib_kina_std_console_printInt(value)

  return
}

export func printBool(value: bool): void {
  kina_lib_kina_std_console_printBool(value)

  return
}